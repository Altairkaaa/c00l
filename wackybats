local function killHB(k) if HB[k] then HB[k]:Disconnect() HB[k]=nil end end
local function getMyHRP() local c=LocalPlayer.Character return c and c:FindFirstChild("HumanoidRootPart") end
local function getMyHum() local c=LocalPlayer.Character return c and c:FindFirstChildOfClass("Humanoid") end
local function isAlive(p) if not p or not p.Character then return false end local h=p.Character:FindFirstChildOfClass("Humanoid") return h~=nil and h.Health>0 end
local function getAliveEnemies()
local pool={}
for _,p in ipairs(Players:GetPlayers()) do
if p==LocalPlayer then continue end
local c=p.Character if not c then continue end
local h=c:FindFirstChild("Humanoid") if not h or h.Health<=0 then continue end
if h:GetState()==Enum.HumanoidStateType.Dead then continue end
if c:FindFirstChildWhichIsA("ForceField",true) then continue end
if not c:FindFirstChild("HumanoidRootPart") then continue end
table.insert(pool,p)
end
return pool
end
local function getPlayerList()
local list={}
for _,p in ipairs(Players:GetPlayers()) do if p~=LocalPlayer then table.insert(list,p.Name) end end
return list
end
local function findTool()
local c=LocalPlayer.Character if not c then return nil end
for _,v in ipairs(c:GetChildren()) do if v:IsA("Tool") then return v end end
end
local function getBatTool(batName)
local char=LocalPlayer.Character
if char and batName then
local t=char:FindFirstChild(batName)
if t and t:IsA("Tool") then return t end
end
local bp=LocalPlayer:FindFirstChild("Backpack")
if bp and batName then
local t=bp:FindFirstChild(batName)
if t and t:IsA("Tool") then return t end
end
return findTool()
end
local OFFSET=Vector3.new(2,0,1)
local function lockToPlayer(target)
    if not isAlive(target) then return end
    local myHRP = getMyHRP()
    local tHRP  = target.Character and target.Character:FindFirstChild("HumanoidRootPart")
    if not myHRP or not tHRP then return end

    local targetPos = tHRP.Position
    local myPos     = targetPos + OFFSET
    myHRP.CFrame    = CFrame.lookAt(myPos, targetPos)
end
local function getBatNames(filter)
local out={}
if not BatRemotes then return out end
for _,child in ipairs(BatRemotes:GetChildren()) do
if child:IsA("RemoteEvent") then
local name=child.Name
if filter=="" or string.find(string.lower(name),string.lower(filter),1,true) then table.insert(out,name) end
end
end
return out
end
local function matchBatToTool(toolName)
if not BatRemotes or not toolName then return nil end
local exact=BatRemotes:FindFirstChild(toolName)
if exact and exact:IsA("RemoteEvent") then return exact.Name end
local lowerTool=string.lower(toolName)
for _,child in ipairs(BatRemotes:GetChildren()) do
if child:IsA("RemoteEvent") then
local lowerName=string.lower(child.Name)
if string.find(lowerTool,lowerName,1,true) or string.find(lowerName,lowerTool,1,true) then return child.Name end
end
end
return nil
end
local function fireBat()
if S.autoDetectBat then
local t=findTool()
if t then
local matched=matchBatToTool(t.Name)
if matched and matched~=S.selectedBat then
S.selectedBat=matched
Rayfield:Notify({Title="Auto-Bat",Content="→ "..matched,Duration=1})
end
end
end
if not S.selectedBat or not BatRemotes then return end
local remote=BatRemotes:FindFirstChild(S.selectedBat)
if not remote or not remote:IsA("RemoteEvent") then return end
local tool=getBatTool(S.selectedBat)
if tool then pcall(function() remote:FireServer(tool) end) end
end
local function fireAbility()
if not S.selectedBat or not BatRemotes then return end
local batRemote=BatRemotes:FindFirstChild(S.selectedBat)
if not batRemote or not batRemote:IsA("RemoteEvent") then return end
local tool=getBatTool(S.selectedBat)
if not tool then return end
for _,r in ipairs(batRemote:GetChildren()) do
if r:IsA("RemoteEvent") then pcall(function() r:FireServer(tool) end) end
end
end
local function getAllRemotes()
local out={}
if not BatRemotes then return out end
for _,child in ipairs(BatRemotes:GetChildren()) do
if child:IsA("RemoteEvent") then
table.insert(out,child)
for _,nested in ipairs(child:GetChildren()) do
if nested:IsA("RemoteEvent") then table.insert(out,nested) end
end
end
end
return out
end
local function getBrowserEntries()
local entries,labels,map={},{},{}
if not BatRemotes then return entries,labels,map end
for _,child in ipairs(BatRemotes:GetChildren()) do
if child:IsA("RemoteEvent") then
local lbl=child.Name.." [BAT]"
table.insert(entries,{label=lbl,remote=child})
table.insert(labels,lbl)
map[lbl]=child
for _,nested in ipairs(child:GetChildren()) do
if nested:IsA("RemoteEvent") then
local lbl2=child.Name.." → "..nested.Name.." [ABILITY]"
table.insert(entries,{label=lbl2,remote=nested})
table.insert(labels,lbl2)
map[lbl2]=nested
end
end
end
end
return entries,labels,map
end
local FALLBACK_POS=Vector3.new(87,229,5)
local function startAutofarmLoop()
S.farmGen=S.farmGen+1
local gen=S.farmGen
killHB("autofarmTP")
HB.autofarmTP=RunService.Heartbeat:Connect(function()
if S.autofarmTarget then lockToPlayer(S.autofarmTarget)
else
local c=LocalPlayer.Character
if c and c:FindFirstChild("HumanoidRootPart") then c.HumanoidRootPart.CFrame=CFrame.new(FALLBACK_POS) end
end
end)
task.spawn(function()
while S.autofarmActive and gen==S.farmGen do
local c=LocalPlayer.Character
local hum=c and c:FindFirstChild("Humanoid")
if not c or not hum or hum.Health<=0 or c:FindFirstChildWhichIsA("ForceField",true) then
S.autofarmTarget=nil
task.wait(1)
continue
end
if not S.autofarmTarget or not isAlive(S.autofarmTarget) then
if S.autofarmTarget and not isAlive(S.autofarmTarget) then S.kills=S.kills+1 end
local pool=getAliveEnemies()
if #pool>0 then
S.autofarmTarget=pool[math.random(1,#pool)]
Rayfield:Notify({Title="Autofarm",Content="→ "..S.autofarmTarget.Name,Duration=2})
else
S.autofarmTarget=nil
task.wait(1)
end
else
local tChar=S.autofarmTarget.Character
if tChar and tChar:FindFirstChildWhichIsA("ForceField",true) then
S.autofarmTarget=nil
task.wait(0.5)
continue
end
if S.autofarmBat then fireBat() end
if S.autofarmAbility then fireAbility() end
task.wait(S.farmDelay)
end
end
if gen==S.farmGen then
S.autofarmTarget=nil
killHB("autofarmTP")
end
end)
end
