CombatTab:CreateSection("Subspace Tripmine Spam")

CombatTab:CreateLabel("⚠️ You must own Subspace Tripbat and have it equipped in the shop.")
CombatTab:CreateLabel("TPs 100 studs above each player, fires 3x, then moves to next.")

CombatTab:CreateToggle({
    Name         = "💥 Subspace Loop Spam",
    CurrentValue = false,
    Flag         = "SubspaceSpam",
    Callback = function(v)
        S.subspaceActive = v

        if not v then return end

        -- grab the subspace tripbat remote
        -- folder name: "Subspace Tripbat", fires whatever RemoteEvent is inside
        local function getSubspaceRemote()
            if not BatRemotes then return nil end
            local folder = BatRemotes:FindFirstChild("Subspace Tripbat")
            if not folder then return nil end
            return folder:FindFirstChildWhichIsA("RemoteEvent")
        end

        task.spawn(function()
            while S.subspaceActive do
                local remote = getSubspaceRemote()
                if not remote then
                    Rayfield:Notify({
                        Title   = "Subspace",
                        Content = "Subspace Tripbat remote not found! Equip the bat.",
                        Duration = 3
                    })
                    task.wait(2)
                    -- keep retrying until found or toggled off
                    continue
                end

                -- build shuffled player pool
                local pool = {}
                for _, p in ipairs(Players:GetPlayers()) do
                    if p ~= LocalPlayer and isAlive(p) then
                        table.insert(pool, p)
                    end
                end

                -- shuffle pool so order is random each cycle
                for i = #pool, 2, -1 do
                    local j = math.random(1, i)
                    pool[i], pool[j] = pool[j], pool[i]
                end

                if #pool == 0 then
                    -- no alive enemies, wait a beat and retry
                    task.wait(1)
                    continue
                end

                -- loop through each player in the pool
                for _, target in ipairs(pool) do
                    if not S.subspaceActive then break end
                    if not isAlive(target) then continue end

                    local myHRP     = getMyHRP()
                    local targetHRP = target.Character and
                                      target.Character:FindFirstChild("HumanoidRootPart")

                    if not myHRP or not targetHRP then continue end

                    -- TP 100 studs directly above the target
                    myHRP.CFrame = CFrame.new(
                        targetHRP.Position.X,
                        targetHRP.Position.Y + 100,
                        targetHRP.Position.Z
                    )

                    -- fire the remote 3 times with the global delay between each
                    for i = 1, 3 do
                        if not S.subspaceActive then break end
                        local tool = findTool()
                        pcall(remote.FireServer, remote, tool)
                        task.wait(S.spamDelay)  -- uses global spamDelay
                    end

                    -- small pause before moving to next target
                    task.wait(S.spamDelay)
                end

                -- pool exhausted — loop resets automatically (while loop continues)
            end
        end)
    end
})
