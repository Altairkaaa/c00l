ESPTab:CreateButton({
    Name     = "📍 List Nearby Players (Sorted)",
    Callback = function()
        local myHRP = getMyHRP()
        if not myHRP then return end

        local entries = {}
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character then
                local tHRP = p.Character:FindFirstChild("HumanoidRootPart")
                if tHRP then
                    local dist = math.floor((myHRP.Position - tHRP.Position).Magnitude)
                    table.insert(entries, { name = p.Name, dist = dist })
                end
            end
        end

        table.sort(entries, function(a, b) return a.dist < b.dist end)

        local lines = {}
        for i, e in ipairs(entries) do
            table.insert(lines, i .. ". " .. e.name .. " — " .. e.dist .. " studs")
        end

        Rayfield:Notify({
            Title    = "Nearby Players",
            Content  = #lines > 0 and table.concat(lines, "\n") or "Nobody nearby.",
            Duration = 6
        })
    end
})

