local function removeESP()
for _,bb in pairs(S.espBillboards) do if bb and bb.Parent then bb:Destroy() end end
S.espBillboards={}
end
local function makeESPTag(player)
if not player.Character then return end
local hrp=player.Character:FindFirstChild("HumanoidRootPart")
if not hrp then return end
local existing=S.espBillboards[player]
if existing and existing.Parent then return end
local bb=Instance.new("BillboardGui")
bb.Name="ENI_ESP" bb.Size=UDim2.new(0,120,0,40)
bb.StudsOffset=Vector3.new(0,3,0) bb.AlwaysOnTop=true
bb.Adornee=hrp bb.Parent=hrp
local label=Instance.new("TextLabel")
label.Size=UDim2.new(1,0,1,0)
label.BackgroundColor3=Color3.fromRGB(0,0,0)
label.BackgroundTransparency=0.5
label.TextColor3=Color3.fromRGB(255,80,80)
label.TextSize=13 label.Font=Enum.Font.GothamBold
label.Text=player.Name label.Parent=bb
Instance.new("UICorner",label).CornerRadius=UDim.new(0,4)
S.espBillboards[player]=bb
end
ESPTab:CreateToggle({Name="👁️ ESP — Show All Players",CurrentValue=false,Flag="ESP",Callback=function(v)
S.espActive=v
if v then
for _,p in ipairs(Players:GetPlayers()) do if p~=LocalPlayer then makeESPTag(p) end end
HB.esp=RunService.Heartbeat:Connect(function()
if not S.espActive then return end
local myHRP=getMyHRP()
for _,p in ipairs(Players:GetPlayers()) do
if p==LocalPlayer then continue end
if not S.espBillboards[p] or not S.espBillboards[p].Parent then makeESPTag(p) end
local bb=S.espBillboards[p]
if not bb or not bb.Parent then continue end
local label=bb:FindFirstChildOfClass("TextLabel")
if not label then continue end
local dist=999
if myHRP and p.Character then
local tHRP=p.Character:FindFirstChild("HumanoidRootPart")
if tHRP then dist=math.floor((myHRP.Position-tHRP.Position).Magnitude) end
end
label.TextColor3=dist<20 and Color3.fromRGB(255,60,60) or dist<60 and Color3.fromRGB(255,200,50) or Color3.fromRGB(80,220,120)
label.Text=p.Name.."\n"..dist.." studs"
end
end)
HB.espPlayerLeft=Players.PlayerRemoving:Connect(function(p) if S.espBillboards[p] then S.espBillboards[p]:Destroy() S.espBillboards[p]=nil end end)
else
killHB("esp") killHB("espPlayerLeft") removeESP()
end
end})
