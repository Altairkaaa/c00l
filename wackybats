-- ── Core helpers ───────────────────────────────────────────────────────────
local function getMyHRP()
    local char = LocalPlayer.Character
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function getMyHum()
    local char = LocalPlayer.Character
    return char and char:FindFirstChildOfClass("Humanoid")
end

local function isAlive(player)
    if not player or not player.Character then return false end
    local hum = player.Character:FindFirstChildOfClass("Humanoid")
    return hum ~= nil and hum.Health > 0
end

local function getAliveEnemies()
    local pool = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and isAlive(p) then
            table.insert(pool, p)
        end
    end
    return pool
end

local function getPlayerList()
    local list = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then table.insert(list, p.Name) end
    end
    return list
end

local function findTool()
    local char = LocalPlayer.Character
    if not char then return nil end
    for _, c in ipairs(char:GetChildren()) do
        if c:IsA("Tool") then return c end
    end
    return nil
end

local OFFSET = Vector3.new(2, 0, 1)

local function lockToPlayer(target)
    if not isAlive(target) then return end
    local myHRP     = getMyHRP()
    local targetHRP = target.Character and
                      target.Character:FindFirstChild("HumanoidRootPart")
    if myHRP and targetHRP then
        myHRP.CFrame = targetHRP.CFrame + OFFSET
    end
end

-- ── Remote helpers ────────────────────────────────────────────────────────
local function getAllRemotes()
    local out = {}
    if not BatRemotes then return out end
    for _, folder in ipairs(BatRemotes:GetChildren()) do
        for _, r in ipairs(folder:GetChildren()) do
            if r:IsA("RemoteEvent") then table.insert(out, r) end
        end
    end
    return out
end

local function getBrowserEntries()
    local entries = {}
    if not BatRemotes then return entries end
    for _, folder in ipairs(BatRemotes:GetChildren()) do
        for _, r in ipairs(folder:GetChildren()) do
            if r:IsA("RemoteEvent") then
                table.insert(entries, {
                    label  = folder.Name .. " → " .. r.Name,
                    remote = r
                })
            end
        end
    end
    return entries
end

local function fireSelected(tool)
    if not S.selectedBat or not tool then return end
    if not BatRemotes then return end  -- [FIX] nil guard
    local folder = BatRemotes:FindFirstChild(S.selectedBat)
    if not folder then return end
    local remote = (S.selectedAbility == "Default")
        and folder:FindFirstChildWhichIsA("RemoteEvent")
        or  folder:FindFirstChild(S.selectedAbility)
    if remote then pcall(remote.FireServer, remote, tool) end
end

local function fire(tool)
    fireSelected(tool)
end

-- ── Autofarm coroutine (reusable) ─────────────────────────────────────────
-- [FIX] extracted into a single function so CharacterAdded and the toggle
--       both call the same logic without duplicating the loop
local function startAutofarmLoop()
    killHB("autofarmTP")
    HB.autofarmTP = RunService.Heartbeat:Connect(function()
        if S.autofarmTarget then lockToPlayer(S.autofarmTarget) end
    end)
    task.spawn(function()
        while S.autofarmActive do
            if not S.autofarmTarget or not isAlive(S.autofarmTarget) then
                if S.autofarmTarget and not isAlive(S.autofarmTarget) then
                    S.kills = S.kills + 1
                end
                local pool = getAliveEnemies()
                if #pool > 0 then
                    S.autofarmTarget = pool[math.random(1, #pool)]
                    Rayfield:Notify({
                        Title   = "Autofarm",
                        Content = "→ " .. S.autofarmTarget.Name,
                        Duration = 2
                    })
                else
                    S.autofarmTarget = nil
                    task.wait(1)
                end
            else
                fire(findTool())
                task.wait(S.farmDelay)  -- [FIX] uses farmDelay not spamDelay
            end
        end
        S.autofarmTarget = nil
        killHB("autofarmTP")
    end)
end

