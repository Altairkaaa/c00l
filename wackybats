-- TAB 5 — ⚔️ Autofarm
-- ─────────────────────────────────────────────────────────────────────────
local FarmTab = Window:CreateTab("Autofarm", 4483362458)
FarmTab:CreateSection("Kill Everyone")

FarmTab:CreateToggle({
    Name         = "🌀 Autofarm — Loop Kill Everyone",
    CurrentValue = false,
    Flag         = "Autofarm",
    Callback = function(v)
        S.autofarmActive = v

        if v then
            HB.autofarmTP = RunService.Heartbeat:Connect(function()
                if S.autofarmTarget then
                    lockToPlayer(S.autofarmTarget)
                end
            end)

            task.spawn(function()
                while S.autofarmActive do
                    if not S.autofarmTarget or not isAlive(S.autofarmTarget) then
                        local pool = getAliveEnemies()
                        if #pool > 0 then
                            S.autofarmTarget = pool[math.random(1, #pool)]
                            Rayfield:Notify({
                                Title   = "Autofarm",
                                Content = "→ " .. S.autofarmTarget.Name,
                                Duration = 2
                            })
                        else
                            S.autofarmTarget = nil
                            task.wait(1)
                        end
                    else
                        fire(findTool())
                        task.wait(S.spamDelay)
                    end
                end

                S.autofarmTarget = nil
                killHB("autofarmTP")
            end)
        else
            S.autofarmActive = false
            S.autofarmTarget = nil
            killHB("autofarmTP")
        end
    end
})

