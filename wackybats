    selectedBat         = nil,
    selectedAbility     = "Default",
    spamActive          = false,
    spamDelay           = 0.05,

    targetPlayer        = nil,
    targetTPActive      = false,
    targetTPSpamActive  = false,

    autofarmActive      = false,
    autofarmTarget      = nil,

    crashActive         = false,
    crashThreads        = 8,      -- number of parallel flood threads

    browserRemote       = nil,    -- currently selected remote in browser
    browserSpamActive   = false,

    noclipActive        = false,
    antiAFKActive       = false,
    walkSpeed           = 16,
    jumpPower           = 50,
}

-- ── Heartbeat slots ────────────────────────────────────────────────────────
local HB = {
    loopTP      = nil,
    loopTPSpam  = nil,
    autofarmTP  = nil,
    noclip      = nil,
}

local function killHB(key)
    if HB[key] then HB[key]:Disconnect() HB[key] = nil end
end

-- ── Helpers ────────────────────────────────────────────────────────────────
local function getMyHRP()
    local char = LocalPlayer.Character
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function isAlive(player)
    if not player or not player.Character then return false end
    local hum = player.Character:FindFirstChildOfClass("Humanoid")
    return hum ~= nil and hum.Health > 0
end

local function getAliveEnemies()
    local pool = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and isAlive(p) then
            table.insert(pool, p)
        end
    end
    return pool
end

local function getPlayerList()
    local list = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then table.insert(list, p.Name) end
    end
    return list
end

local function findTool()
    local char = LocalPlayer.Character
    if not char then return nil end
    for _, c in ipairs(char:GetChildren()) do
        if c:IsA("Tool") then return c end
    end
end

local OFFSET = Vector3.new(2, 0, 1)

local function lockToPlayer(target)
    if not isAlive(target) then return end
    local myHRP     = getMyHRP()
    local targetHRP = target.Character and
                      target.Character:FindFirstChild("HumanoidRootPart")
    if myHRP and targetHRP then
        myHRP.CFrame = targetHRP.CFrame + OFFSET
    end
end

-- ── Remote helpers ────────────────────────────────────────────────────────
--[[
    getAllRemotes() returns a flat array of every RemoteEvent
    across every folder inside BatRemotes. Used by crash + browser.
]]
local function getAllRemotes()
    local out = {}
    if not BatRemotes then return out end
    for _, folder in ipairs(BatRemotes:GetChildren()) do
        for _, r in ipairs(folder:GetChildren()) do
            if r:IsA("RemoteEvent") then
                table.insert(out, r)
            end
        end
    end
    return out
end

--[[
    getBrowserEntries() — same as above but returns structured entries
    so the browser tab can display "BatName → AbilityName" labels
    and map them back to the actual RemoteEvent object.
]]
local function getBrowserEntries()
    local entries = {}   -- { label = string, remote = RemoteEvent }
    if not BatRemotes then return entries end
    for _, folder in ipairs(BatRemotes:GetChildren()) do
        for _, r in ipairs(folder:GetChildren()) do
            if r:IsA("RemoteEvent") then
                table.insert(entries, {
                    label  = folder.Name .. " → " .. r.Name,
                    remote = r
                })
            end
        end
    end
    return entries
end

local function fireSelected(tool)
    if not S.selectedBat or not tool then return end
    local folder = BatRemotes:FindFirstChild(S.selectedBat)
    if not folder then return end
    local remote = (S.selectedAbility == "Default")
        and folder:FindFirstChildWhichIsA("RemoteEvent")
        or  folder:FindFirstChild(S.selectedAbility)
    if remote then pcall(remote.FireServer, remote, tool) end
end

local function fire(tool)
    fireSelected(tool)
end

